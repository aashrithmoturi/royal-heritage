# Environment Variables for The Farmhouse

# Contact & Booking Details (update in lib/site.ts)
# These are centralized in lib/site.ts for consistency across all sections

# Optional: Google Maps API Key (if using custom embedded maps)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Analytics & Third-Party Services
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTAG_ID=

# Build-time variables
# NODE_ENV is set automatically by Vercel/Next.js
